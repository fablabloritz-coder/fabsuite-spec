# ═══════════════════════════════════════════════════════════════
#  FabLab Suite — Variables d'environnement
#  Copiez ce fichier en .env et ajustez selon votre installation
#    cp .env.example .env   (Linux/macOS)
#    copy .env.example .env  (Windows)
# ═══════════════════════════════════════════════════════════════

# Fuseau horaire
TZ=Europe/Paris

# Clé secrète Flask partagée (laisser vide = générée automatiquement par chaque app)
# Recommandé en production : python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# ─────────────────────────────────────────
#  Ports (modifiez si conflit avec vos services existants)
# ─────────────────────────────────────────
FABHOME_PORT=3001
FABTRACK_PORT=5555
PRETGO_PORT=5000
FABBOARD_PORT=5580

# ─────────────────────────────────────────
#  Interconnexion FabBoard → Fabtrack
#  En déploiement serveur, remplacez host.docker.internal par l'IP ou hostname du serveur
# ─────────────────────────────────────────
FABTRACK_URL=http://host.docker.internal:5555

# ─────────────────────────────────────────
#  Chemins des données (optionnel)
#  Par défaut les données sont stockées dans docker-data/ de chaque app
# ─────────────────────────────────────────
# FABTRACK_DATA_PATH=../Fabtrack/docker-data/data
# FABTRACK_UPLOADS_PATH=../Fabtrack/docker-data/uploads
# PRETGO_DATA_PATH=../PretGo/docker-data/data
# PRETGO_UPLOADS_PATH=../PretGo/docker-data/uploads/materiel
# FABBOARD_DATA_PATH=../FabBoard/docker-data/data
